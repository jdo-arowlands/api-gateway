# ── Database ──────────────────────────────────────────────────────────────────
# Railway auto-injects this when you add a Postgres plugin.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/api_gateway

# ── Dashboard login (REQUIRED for security) ───────────────────────────────────
# A single shared admin login protects the whole dashboard and API.
# If DASHBOARD_PASSWORD is left blank, the dashboard runs OPEN (local dev only).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# Secret key — signs the login session cookie. MUST be set in production.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Optional ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
