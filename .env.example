# ── Database ──────────────────────────────────────────────────────────────────
# Railway auto-injects this when you add a Postgres plugin.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/api_gateway

# ── App ────────────────────────────────────────────────────────────────────────
# Secret key for signing any internal tokens / HMAC webhook verification
SECRET_KEY=change-me-to-a-long-random-string

# Basic auth to protect the dashboard (leave blank to disable)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# ── Optional ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
